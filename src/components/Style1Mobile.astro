---
---
<main class="relative isolate min-h-screen overflow-hidden bg-[hsl(var(--background))] text-[hsl(var(--foreground))] md:hidden">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute left-1/2 top-[-28rem] h-[780px] w-[920px] -translate-x-1/2 rounded-[50%] bg-[radial-gradient(ellipse_at_center,_rgba(138,216,255,0.85)_0%,_rgba(77,170,255,0.64)_30%,_rgba(22,109,236,0.35)_56%,_transparent_85%)] blur-[62px]"></div>
    <div class="absolute left-1/2 top-[18rem] h-[340px] w-[520px] -translate-x-1/2 rounded-full bg-[radial-gradient(ellipse_at_center,_rgba(169,223,255,0.28)_0%,_rgba(74,151,255,0.18)_48%,_transparent_78%)] blur-[46px]"></div>
  </div>

  <div class="relative mx-auto max-w-md px-4 pb-14 pt-6">
    <header class="flex items-center justify-between">
      <a href="#" class="text-lg font-semibold tracking-tight text-white">markup<span class="text-cyan-300">|</span></a>
      <a class="btn-ghost inline-flex items-center gap-2 px-4 py-2 text-xs" href="https://markup.freddiephilpot.dev?source=home&version=latest&platform=mobile">
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
          <path d="M13 5a1 1 0 1 1 0-2h6a1 1 0 0 1 1 1v6a1 1 0 1 1-2 0V6.41l-8.3 8.3a1 1 0 0 1-1.4-1.42L16.59 5H13ZM5 7a2 2 0 0 1 2-2h2a1 1 0 1 1 0 2H7v10h10v-2a1 1 0 1 1 2 0v2a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V7Z"></path>
        </svg>
        <span>Open on Web</span>
      </a>
    </header>

    <section class="mt-10 animate-rise">
      <p class="text-xs uppercase tracking-[0.2em] text-cyan-200">Mobile View</p>
      <h1 class="mt-3 text-balance text-4xl font-semibold leading-tight text-white">
        Markup for fast notes on smaller screens.
      </h1>
      <p class="mt-4 text-sm leading-relaxed text-slate-300">
        Write, organize, and share markdown notes with the same connected workspace experience, tuned for one-hand reading and quick edits.
      </p>
      <div class="mt-6 grid gap-3">
        <a class="btn-primary inline-flex items-center justify-center gap-2 px-6 py-3 text-sm" href="https://markup.freddiephilpot.dev?source=home&version=latest&platform=mobile" data-download-button>
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
            <path data-download-icon d="M11 4a1 1 0 1 1 2 0v8.59l2.3-2.3a1 1 0 1 1 1.4 1.42l-4 4a1 1 0 0 1-1.4 0l-4-4a1 1 0 0 1 1.4-1.42l2.3 2.3V4ZM5 18a1 1 0 0 1 1-1h12a1 1 0 1 1 0 2H6a1 1 0 0 1-1-1Z"></path>
          </svg>
          <span data-download-text>Open Markup PWA</span>
        </a>
        <a class="btn-ghost inline-flex items-center justify-center gap-2 px-6 py-3 text-sm" href="https://docs.markup.freddiephilpot.dev">
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
            <path d="M5 11a3 3 0 0 1 3-3h8a3 3 0 0 1 3 3v7a3 3 0 0 1-3 3H8a3 3 0 0 1-3-3v-7Zm3-1a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1v-7a1 1 0 0 0-1-1H8Zm1-6a1 1 0 0 1 1-1h4a1 1 0 1 1 0 2h-4a1 1 0 0 1-1-1Z"></path>
          </svg>
          <span>Read Docs</span>
        </a>
      </div>
    </section>

    <section class="relative mt-8 rounded-3xl border border-white/12 bg-[linear-gradient(170deg,rgba(10,24,60,0.9),rgba(6,13,35,0.95))] p-3 shadow-[0_0_48px_rgba(23,73,200,0.22)]">
      <div class="surface-soft overflow-hidden rounded-2xl p-2">
        <img
          src="/app.png"
          alt="Markup app interface preview"
          class="h-auto w-full rounded-xl border border-white/10 object-cover"
          loading="eager"
        />
      </div>
    </section>

    <section class="mt-10 space-y-3">
      <article class="surface-soft rounded-2xl p-4">
        <p class="text-xs uppercase tracking-[0.16em] text-cyan-200">Flow</p>
        <h2 class="mt-2 text-xl font-semibold text-white">Write and preview side by side.</h2>
        <p class="mt-2 text-sm text-slate-300">Markdown editing, instant preview, and structured note links stay in sync as you type.</p>
      </article>
      <article class="surface-soft rounded-2xl p-4">
        <p class="text-xs uppercase tracking-[0.16em] text-cyan-200">Graph</p>
        <h2 class="mt-2 text-xl font-semibold text-white">Map connected ideas quickly.</h2>
        <p class="mt-2 text-sm text-slate-300">Jump through backlinks, whiteboards, and mind maps without losing the note you started from.</p>
      </article>
      <article class="surface-soft rounded-2xl p-4">
        <p class="text-xs uppercase tracking-[0.16em] text-cyan-200">Share</p>
        <h2 class="mt-2 text-xl font-semibold text-white">Publish safely in one tap.</h2>
        <p class="mt-2 text-sm text-slate-300">Create read-only links for public updates or private teammate access with your source untouched.</p>
      </article>
    </section>

    <section class="mt-10">
      <p class="text-center text-xs uppercase tracking-[0.16em] text-slate-400">Trusted by teams</p>
      <div class="mt-5 grid grid-cols-3 items-center justify-items-center gap-4 rounded-2xl border border-white/10 bg-[rgba(7,14,36,0.6)] px-4 py-5">
        <img src="/logos/figma.svg" alt="Figma logo" class="h-7 w-auto opacity-90" loading="lazy" />
        <img src="/logos/stripe.svg" alt="Stripe logo" class="h-7 w-auto opacity-90" loading="lazy" />
        <img src="/logos/dropbox.svg" alt="Dropbox logo" class="h-7 w-auto opacity-90" loading="lazy" />
        <img src="/logos/zoom.svg" alt="Zoom logo" class="h-7 w-auto opacity-90" loading="lazy" />
        <img src="/logos/airbnb.svg" alt="Airbnb logo" class="h-7 w-auto opacity-90" loading="lazy" />
        <img src="/logos/atlassian.svg" alt="Atlassian logo" class="h-7 w-auto opacity-90" loading="lazy" />
      </div>
    </section>

    <section class="mt-10 rounded-3xl border border-cyan-300/20 bg-[linear-gradient(165deg,rgba(7,20,51,0.95),rgba(8,31,83,0.84))] px-5 py-8 text-center shadow-[0_0_42px_rgba(34,134,255,0.2)]">
      <p class="text-xs uppercase tracking-[0.2em] text-cyan-100/80">Markup</p>
      <h3 class="mt-3 text-2xl font-semibold text-white">Bring your workspace anywhere.</h3>
      <p class="mt-3 text-sm text-slate-300">Install Markup and keep your markdown workflow in your pocket.</p>
      <a class="btn-primary mt-5 inline-flex items-center gap-2 px-6 py-3 text-sm" href="https://markup.freddiephilpot.dev?source=home&version=latest&platform=mobile" data-download-button>
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
          <path data-download-icon d="M11 4a1 1 0 1 1 2 0v8.59l2.3-2.3a1 1 0 1 1 1.4 1.42l-4 4a1 1 0 0 1-1.4 0l-4-4a1 1 0 0 1 1.4-1.42l2.3 2.3V4ZM5 18a1 1 0 0 1 1-1h12a1 1 0 1 1 0 2H6a1 1 0 0 1-1-1Z"></path>
        </svg>
        <span data-download-text>Open Markup PWA</span>
      </a>
    </section>
  </div>
</main>
