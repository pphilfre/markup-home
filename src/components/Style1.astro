---
---
<main class="relative isolate hidden min-h-screen overflow-hidden bg-[hsl(var(--background))] text-[hsl(var(--foreground))] md:block">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute left-1/2 top-[-62rem] h-[1660px] w-[2720px] -translate-x-1/2 rounded-[50%] bg-[radial-gradient(ellipse_at_center,_rgba(138,216,255,0.95)_0%,_rgba(102,196,255,0.84)_18%,_rgba(66,164,255,0.72)_34%,_rgba(36,132,255,0.58)_49%,_rgba(16,96,238,0.4)_63%,_rgba(8,58,188,0.24)_75%,_transparent_90%)] [mask-image:radial-gradient(ellipse_at_center,_transparent_46%,_rgba(0,0,0,0.08)_51%,_rgba(0,0,0,0.36)_56%,_rgba(0,0,0,0.68)_62%,_rgba(0,0,0,0.84)_69%,_rgba(0,0,0,0.58)_76%,_rgba(0,0,0,0.2)_84%,_transparent_91%)] blur-[96px]"></div>
    <div class="absolute left-1/2 top-[8.5rem] h-[320px] w-[700px] -translate-x-[-22%] rounded-full bg-[radial-gradient(ellipse_at_center,_rgba(228,248,255,0.56)_0%,_rgba(176,226,255,0.36)_36%,_rgba(106,188,255,0.18)_60%,_transparent_88%)] blur-[88px]"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-6 pb-24 pt-10 md:px-10">
    <header class="flex items-center justify-between px-1 py-3 text-sm md:px-2">
      <a href="#" class="text-base font-semibold tracking-tight text-white">markup<span class="text-cyan-300">|</span></a>
      <nav class="hidden items-center gap-12 text-slate-300 md:flex">
        <a class="transition hover:text-white" href="https://github.com/pphilfre/markup-home">GitHub</a>
        <a class="transition hover:text-white" href="https://docs.markup.freddiephilpot.dev">Docs</a>
        <a class="transition hover:text-white" href="#about">About</a>
      </nav>
      <a class="btn-ghost inline-flex items-center gap-2 px-5 py-2 text-xs md:text-sm" href="https://markup.freddiephilpot.dev?source=home&version=latest&platform=web">
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
          <path d="M13 5a1 1 0 1 1 0-2h6a1 1 0 0 1 1 1v6a1 1 0 1 1-2 0V6.41l-8.3 8.3a1 1 0 0 1-1.4-1.42L16.59 5H13ZM5 7a2 2 0 0 1 2-2h2a1 1 0 1 1 0 2H7v10h10v-2a1 1 0 1 1 2 0v2a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V7Z"></path>
        </svg>
        <span>Open on Web</span>
      </a>
    </header>

    <section class="mx-auto mt-16 max-w-4xl text-center md:mt-24 animate-rise">
      <h1 class="text-pretty text-4xl font-semibold leading-tight text-white sm:text-5xl md:text-7xl">
        The AI Markdown Workspace
        <span class="bg-gradient-to-r from-white via-blue-100 to-cyan-300 bg-clip-text text-transparent">For High-Context Teams</span>
      </h1>
      <p class="mx-auto mt-7 max-w-3xl text-balance text-base text-slate-300 md:text-lg">
        Markup combines keyboard-first writing, live markdown preview, graph view, whiteboards, and mind maps so every note stays connected and actionable.
      </p>
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a class="btn-primary inline-flex items-center gap-2 px-7 py-3 text-sm" href="https://github.com/pphilfre/markup/releases?version=latest&platform=desktop" data-download-button>
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
            <path data-download-icon d="M11 4a1 1 0 1 1 2 0v8.59l2.3-2.3a1 1 0 1 1 1.4 1.42l-4 4a1 1 0 0 1-1.4 0l-4-4a1 1 0 0 1 1.4-1.42l2.3 2.3V4ZM5 18a1 1 0 0 1 1-1h12a1 1 0 1 1 0 2H6a1 1 0 0 1-1-1Z"></path>
          </svg>
          <span data-download-text>Download for Desktop</span>
        </a>
        <a class="btn-ghost inline-flex items-center gap-2 px-7 py-3 text-sm" href="https://markup.freddiephilpot.dev?source=home&version=latest&platform=web">
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
            <path d="M13 5a1 1 0 1 1 0-2h6a1 1 0 0 1 1 1v6a1 1 0 1 1-2 0V6.41l-8.3 8.3a1 1 0 0 1-1.4-1.42L16.59 5H13ZM5 7a2 2 0 0 1 2-2h2a1 1 0 1 1 0 2H7v10h10v-2a1 1 0 1 1 2 0v2a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V7Z"></path>
          </svg>
          <span>Open on Web</span>
        </a>
      </div>
    </section>

    <section class="relative mt-16 rounded-3xl border border-white/10 bg-[linear-gradient(180deg,rgba(11,19,52,0.95),rgba(5,9,27,0.95))] p-5 shadow-[0_0_90px_rgba(23,73,200,0.26)] md:mt-20 md:p-8">
      <div class="pointer-events-none absolute inset-0 rounded-3xl border border-cyan-400/8"></div>
      <div class="surface-soft overflow-hidden rounded-2xl p-3 md:p-4">
        <div class="mb-4 flex gap-2 px-2 pt-1">
          <span class="h-2.5 w-2.5 rounded-full bg-red-400"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-amber-300"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-emerald-400"></span>
        </div>
        <img
          src="/app.png"
          alt="Markup app interface preview"
          class="h-auto w-full rounded-xl border border-white/10 object-cover"
          loading="eager"
        />
      </div>
    </section>

    <section id="about" class="mt-14 text-center text-sm text-slate-400 md:mt-16">
      <p>Trusted by fast-moving teams building docs, products, and research.</p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-x-16 gap-y-8 md:gap-x-24 lg:gap-x-28">
        <img src="/logos/figma.svg" alt="Figma logo" class="h-9 w-auto opacity-90 transition duration-200 hover:opacity-100 md:h-10" loading="lazy" />
        <img src="/logos/stripe.svg" alt="Stripe logo" class="h-9 w-auto opacity-90 transition duration-200 hover:opacity-100 md:h-10" loading="lazy" />
        <img src="/logos/dropbox.svg" alt="Dropbox logo" class="h-9 w-auto opacity-90 transition duration-200 hover:opacity-100 md:h-10" loading="lazy" />
        <img src="/logos/zoom.svg" alt="Zoom logo" class="h-9 w-auto opacity-90 transition duration-200 hover:opacity-100 md:h-10" loading="lazy" />
        <img src="/logos/airbnb.svg" alt="Airbnb logo" class="h-9 w-auto opacity-90 transition duration-200 hover:opacity-100 md:h-10" loading="lazy" />
        <img src="/logos/atlassian.svg" alt="Atlassian logo" class="h-9 w-auto opacity-90 transition duration-200 hover:opacity-100 md:h-10" loading="lazy" />
      </div>
    </section>

    <section id="how-it-works" class="mt-24 md:mt-28">
      <h2 class="text-center text-4xl font-semibold text-white md:text-5xl">How It Works</h2>
      <div id="features" class="mt-12 space-y-12 md:mt-14 md:space-y-16">
        <article class="grid min-h-[380px] items-center gap-y-10 md:min-h-[430px] md:grid-cols-2 md:gap-x-16 lg:gap-x-24">
          <div class="max-w-xl">
            <p class="text-xs uppercase tracking-[0.18em] text-cyan-200">Works everywhere</p>
            <h3 class="mt-3 text-3xl font-semibold text-white">Write once, stay in flow.</h3>
            <p class="mt-4 text-slate-300">
              Markup syncs your workspace and tabs per user with Convex while staying offline-aware, so your notes are consistent across web and desktop.
            </p>
          </div>
          <div class="surface-soft diagram-card sync-diagram relative h-[280px] overflow-hidden rounded-2xl p-4 md:h-[340px]" role="img" aria-label="Orbital sync map connecting web, desktop, and shared views.">
            <svg class="sync-lines" viewBox="0 0 100 100" aria-hidden="true">
              <line class="sync-link link-web" x1="50" y1="50" x2="19" y2="21"></line>
              <line class="sync-link link-desktop" x1="50" y1="50" x2="82" y2="22"></line>
              <line class="sync-link link-offline" x1="50" y1="50" x2="18" y2="78"></line>
              <line class="sync-link link-share" x1="50" y1="50" x2="82" y2="79"></line>
              <circle class="sync-ring ring-one" cx="50" cy="50" r="18"></circle>
              <circle class="sync-ring ring-two" cx="50" cy="50" r="23"></circle>
            </svg>

            <div class="sync-core">
              <span>Markup Workspace</span>
              <small>Cloud + local memory</small>
            </div>

            <button type="button" class="sync-chip chip-web">
              <strong>Web</strong>
              <span>Live docs</span>
            </button>
            <button type="button" class="sync-chip chip-desktop">
              <strong>Desktop</strong>
              <span>File sync</span>
            </button>
            <button type="button" class="sync-chip chip-offline">
              <strong>Offline</strong>
              <span>Safe edits</span>
            </button>
            <button type="button" class="sync-chip chip-share">
              <strong>Shared view</strong>
              <span>Read-only</span>
            </button>

            <span class="sync-pulse" aria-hidden="true"></span>
          </div>
        </article>

        <article id="workflow" class="grid min-h-[380px] items-center gap-y-10 md:min-h-[430px] md:grid-cols-2 md:gap-x-16 lg:gap-x-24">
          <div class="surface-soft diagram-card workflow-diagram relative h-[280px] overflow-hidden rounded-2xl p-4 md:order-1 md:h-[340px]" role="img" aria-label="Layered workspace canvases that shift between editor, graph, and board contexts.">
            <div class="workflow-panel panel-editor">
              <p>Editor</p>
              <span></span>
              <span></span>
              <span></span>
            </div>
            <div class="workflow-panel panel-preview">
              <p>Preview</p>
              <span></span>
              <span></span>
              <span></span>
            </div>
            <div class="workflow-panel panel-graph">
              <p>Graph</p>
              <span></span>
              <span></span>
              <span></span>
            </div>

            <div class="workflow-rail" aria-hidden="true">
              <i class="rail-dot dot-one"></i>
              <i class="rail-dot dot-two"></i>
              <i class="rail-dot dot-three"></i>
            </div>

            <div class="workflow-tags" aria-hidden="true">
              <span>Split</span>
              <span>Whiteboard</span>
              <span>Mind map</span>
              <span>Backlinks</span>
            </div>
          </div>
          <div class="max-w-xl md:order-2">
            <p class="text-xs uppercase tracking-[0.18em] text-cyan-200">Custom workflow</p>
            <h3 class="mt-3 text-3xl font-semibold text-white">Switch context without losing structure.</h3>
            <p class="mt-4 text-slate-300">
              Move between writing, visual mapping, and backlink exploration instantly while keeping everything tied to the same source notes.
            </p>
          </div>
        </article>

        <article id="share" class="grid min-h-[380px] items-center gap-y-10 md:min-h-[430px] md:grid-cols-2 md:gap-x-16 lg:gap-x-24">
          <div class="max-w-xl">
            <p class="text-xs uppercase tracking-[0.18em] text-cyan-200">Share in one click</p>
            <h3 class="mt-3 text-3xl font-semibold text-white">Send polished notes, keep your workspace private.</h3>
            <p class="mt-4 text-slate-300">
              Publish read-only links in public or private mode so teammates can consume updates without touching your internal editing flow.
            </p>
          </div>
          <div class="surface-soft diagram-card share-diagram relative h-[280px] overflow-hidden rounded-2xl p-4 md:h-[340px]" role="img" aria-label="Dual-lane publishing animation for public and private read-only links.">
            <svg class="share-lines" viewBox="0 0 100 100" aria-hidden="true">
              <path class="share-path" d="M14 50 H36 C44 50 46 35 56 35 H87"></path>
              <path class="share-path" d="M14 50 H36 C44 50 46 65 56 65 H87"></path>
              <circle class="share-tracer tracer-up" cx="14" cy="50" r="1.3"></circle>
              <circle class="share-tracer tracer-down" cx="14" cy="50" r="1.3"></circle>
            </svg>

            <div class="share-badge badge-source">
              <strong>Draft</strong>
              <span>Source note</span>
            </div>
            <div class="share-badge badge-public">
              <strong>Public</strong>
              <span>Open URL</span>
            </div>
            <div class="share-badge badge-private">
              <strong>Private</strong>
              <span>Team auth</span>
            </div>
            <div class="share-badge badge-reader-public">
              <strong>Readers</strong>
            </div>
            <div class="share-badge badge-reader-private">
              <strong>Team</strong>
            </div>

            <div class="share-lock" aria-hidden="true">
              <span>Read-only</span>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section id="cta" class="mt-24 rounded-3xl border border-cyan-300/20 bg-[linear-gradient(160deg,rgba(6,18,46,0.95),rgba(8,32,82,0.82))] px-6 py-14 text-center shadow-[0_0_60px_rgba(34,134,255,0.26)] md:px-12">
      <p class="text-xs uppercase tracking-[0.2em] text-cyan-100/80">Markup</p>
      <h3 class="mt-4 text-3xl font-semibold text-white md:text-4xl">Build your second brain in markdown.</h3>
      <p class="mx-auto mt-4 max-w-2xl text-slate-300">
        Download Markup for your platform and jump right into your keyboard-first markdown workspace.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a class="btn-primary inline-flex items-center gap-2 px-7 py-3 text-sm" href="https://github.com/pphilfre/markup/releases?version=latest&platform=desktop" data-download-button>
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
            <path data-download-icon d="M11 4a1 1 0 1 1 2 0v8.59l2.3-2.3a1 1 0 1 1 1.4 1.42l-4 4a1 1 0 0 1-1.4 0l-4-4a1 1 0 0 1 1.4-1.42l2.3 2.3V4ZM5 18a1 1 0 0 1 1-1h12a1 1 0 1 1 0 2H6a1 1 0 0 1-1-1Z"></path>
          </svg>
          <span data-download-text>Download for Desktop</span>
        </a>
        <a class="btn-ghost inline-flex items-center gap-2 px-7 py-3 text-sm" href="https://markup.freddiephilpot.dev?source=home&version=latest&platform=web">
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
            <path d="M13 5a1 1 0 1 1 0-2h6a1 1 0 0 1 1 1v6a1 1 0 1 1-2 0V6.41l-8.3 8.3a1 1 0 0 1-1.4-1.42L16.59 5H13ZM5 7a2 2 0 0 1 2-2h2a1 1 0 1 1 0 2H7v10h10v-2a1 1 0 1 1 2 0v2a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V7Z"></path>
          </svg>
          <span>Open on Web</span>
        </a>
      </div>
    </section>
  </div>

  <script is:inline>
    (() => {
      const ua = navigator.userAgent || "";
      const platform = navigator.platform || "";
      const releasesUrl = "https://github.com/pphilfre/markup/releases";
      const latestManifestUrl = "https://github.com/pphilfre/markup/releases/latest/download/latest.json";
      const pwaUrl = "https://markup.freddiephilpot.dev";

      const icons = {
        default: "M11 4a1 1 0 1 1 2 0v8.59l2.3-2.3a1 1 0 1 1 1.4 1.42l-4 4a1 1 0 0 1-1.4 0l-4-4a1 1 0 0 1 1.4-1.42l2.3 2.3V4ZM5 18a1 1 0 0 1 1-1h12a1 1 0 1 1 0 2H6a1 1 0 0 1-1-1Z",
        mobile: "M8 3.5h8A2.5 2.5 0 0 1 18.5 6v12a2.5 2.5 0 0 1-2.5 2.5H8A2.5 2.5 0 0 1 5.5 18V6A2.5 2.5 0 0 1 8 3.5Zm3 1.5h2a.5.5 0 1 1 0 1h-2a.5.5 0 0 1 0-1ZM12 18.5a1.1 1.1 0 1 0 0 2.2 1.1 1.1 0 0 0 0-2.2Z",
        macos: "M4 5.5A2.5 2.5 0 0 1 6.5 3h11A2.5 2.5 0 0 1 20 5.5v8A2.5 2.5 0 0 1 17.5 16H14v2h2a1 1 0 1 1 0 2H8a1 1 0 1 1 0-2h2v-2H6.5A2.5 2.5 0 0 1 4 13.5v-8Zm2.5-.5a.5.5 0 0 0-.5.5v8c0 .28.22.5.5.5h11a.5.5 0 0 0 .5-.5v-8a.5.5 0 0 0-.5-.5h-11Z",
        windows: "M3 4.5 10.5 3.4V11H3V4.5Zm10.5-1.5L21 2v9h-7.5V3ZM3 13h7.5v7.6L3 19.5V13Zm10.5 0H21v9l-7.5-1.1V13Z"
      };

      const isMobile = /Android|iPhone|iPad|iPod/i.test(ua);
      const isMac = /Mac/i.test(platform) || /Mac OS X/i.test(ua);
      const isWindows = /Win/i.test(platform) || /Windows/i.test(ua);

      let label = "Download for Desktop";
      let iconPath = icons.default;
      let platformKey = "desktop";
      let fallbackUrl = `${releasesUrl}?version=latest&platform=desktop`;

      if (isMobile) {
        label = "Open Markup PWA";
        iconPath = icons.mobile;
        platformKey = "mobile-pwa";
        fallbackUrl = `${pwaUrl}?source=home&version=latest&platform=mobile`;
      } else if (isMac) {
        label = "Download for macOS";
        iconPath = icons.macos;
        platformKey = "darwin-aarch64";
        fallbackUrl = `${releasesUrl}?version=latest&platform=darwin-aarch64`;
      } else if (isWindows) {
        label = "Download for Windows";
        iconPath = icons.windows;
        platformKey = "windows-x86_64-nsis";
        fallbackUrl = `${releasesUrl}?version=latest&platform=windows-x86_64-nsis`;
      }

      const downloadButtons = Array.from(document.querySelectorAll("[data-download-button]"));

      const setDownloadHref = (url) => {
        downloadButtons.forEach((el) => {
          el.setAttribute("href", url);
        });
      };

      const withVersionTag = (url, version, detectedPlatform) => {
        const sep = url.includes("?") ? "&" : "?";
        return `${url}${sep}version=${encodeURIComponent(version)}&platform=${encodeURIComponent(detectedPlatform)}`;
      };

      document.querySelectorAll("[data-download-text]").forEach((el) => {
        el.textContent = label;
      });

      document.querySelectorAll("[data-download-icon]").forEach((el) => {
        el.setAttribute("d", iconPath);
      });

      setDownloadHref(fallbackUrl);

      if (isMobile) {
        return;
      }

      fetch(latestManifestUrl)
        .then((response) => {
          if (!response.ok) {
            throw new Error("Failed to fetch latest release manifest");
          }
          return response.json();
        })
        .then((manifest) => {
          const releaseVersion = manifest?.version || "latest";
          const platforms = manifest?.platforms || {};
          const asset = platforms[platformKey]
            || (isWindows ? platforms["windows-x86_64"] : null)
            || (isMac ? platforms["darwin-aarch64-app"] : null);

          if (!asset?.url) {
            setDownloadHref(`${releasesUrl}?version=${encodeURIComponent(releaseVersion)}&platform=${encodeURIComponent(platformKey)}`);
            return;
          }

          setDownloadHref(withVersionTag(asset.url, releaseVersion, platformKey));
        })
        .catch(() => {
          setDownloadHref(fallbackUrl);
        });
    })();
  </script>
</main>